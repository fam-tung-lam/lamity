root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
ktlint_code_style = ktlint_official

# Compose: allow PascalCase @Composable function names.
ktlint_function_naming_ignore_when_annotated_with = Composable

# Match Kotlin official/IntelliJ trailing-comma style.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

# Kotlin official import ordering.
ij_kotlin_imports_layout = *,java.**,javax.**,kotlin.**,

# Keep IntelliJ/Android Studio from creating wildcard imports that ktlint forbids.
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_name_count_to_use_star_import_for_members = 2147483647
ij_kotlin_packages_to_use_import_on_demand = unset

# KMP platform-specific files commonly use Foo.android.kt / Foo.ios.kt.
ktlint_standard_filename = disabled

# Keep larger declarations/chains readable by making them explicitly multiline.
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 4
ktlint_class_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 4
ktlint_function_signature_body_expression_wrapping = multiline
ktlint_chain_method_rule_force_multiline_when_chain_operator_count_greater_or_equal_than = 4

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 4

[*.toml]
indent_size = 4
